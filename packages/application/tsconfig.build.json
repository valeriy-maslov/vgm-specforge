{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "types": [
      "node"
    ],
    "baseUrl": "../..",
    "paths": {
      "@specforge/contracts": [
        "packages/contracts/dist/index.d.ts"
      ],
      "@specforge/domain": [
        "packages/domain/dist/index.d.ts"
      ]
    },
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ]
}
